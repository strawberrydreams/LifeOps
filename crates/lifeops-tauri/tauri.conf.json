{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LifeOps",
  "version": "0.1.0",
  "identifier": "com.lifeops.desktop",
  "build": { "frontendDist": "ui" },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "LifeOps",
        "width": 1100,
        "height": 780,
        "url": "index.html"
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "icon": ["icons/icon.icns", "icons/icon.png"]
  }
}
